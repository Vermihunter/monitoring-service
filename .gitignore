# --- Dependency Directories ---
node_modules/
jspm_packages/

# --- Build Outputs ---
dist/
build/
.next/
out/
*.tsbuildinfo

# --- Microservice Specifics ---
# We ignore the .tgz files because they are generated artifacts. 
# You don't want to bloat git with binary archives.
*.tgz

# --- Environment & Secrets ---
.env
*.env.local
.env.production
# Keep the example version so others know what keys to use
!.env.example

# --- Docker ---
.docker-data/
# If you store database volumes locally during dev
mongo-data/
redis-data/

# --- Logs & Debug ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- IDE & OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db